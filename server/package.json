{
  "name": "llmarena-server",
  "version": "0.1.0",
  "description": "LLMArena backend - Chess referee for LLM matchups",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "batch:sequential:6games": "tsx src/research/sequential-cli.ts 6games",
    "batch:sequential:test": "tsx src/research/sequential-cli.ts test",
    "batch:sequential:custom": "tsx src/research/sequential-cli.ts custom",
    "batch:sequential": "tsx src/research/sequential-cli.ts"
  },
  "keywords": [
    "chess",
    "llm",
    "arena",
    "game",
    "socket.io"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "chess.js": "^1.0.0-beta.8",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "tsx": "^3.12.7",
    "typescript": "^5.1.3",
    "vitest": "^0.33.0"
  }
}
