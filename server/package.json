{
  "name": "neurlaplay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "batch:ollama:quick": "tsx src/research/sequential-cli.ts --config ../research/configs/batch_config_ollama_quick_test.json",
    "research:paper": "tsx src/research/paper-cli.ts",
    "research:50games": "npm run research:paper -- --games=50",
    "research:100games": "npm run research:paper -- --games=100",
    "research:audit": "tsx src/research/rule-audit-cli.ts",
    "research:audit:latest": "tsx src/research/rule-audit-cli.ts --latest",
    "check:preflight": "tsx src/tools/preflight.ts",
    "research:sanity": "tsx src/research/sequential-cli.ts --config ../research/configs/sanity_smoketest.json"
  },
  "dependencies": {
    "chess.js": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "stockfish": "^17.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
