{
  "name": "neurlaplay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "research:reset": "tsx src/tools/reset-paper-data.ts",
    "research:budget": "tsx src/tools/estimate-paper-budget.ts",
    "research:paper": "tsx src/research/paper-cli.ts --config ../paper/configs/main/main_1200_games.json",
    "research:pilot": "tsx src/research/paper-cli.ts --config ../paper/configs/pilot/pilot_300_games.json",
    "research:smoke": "tsx src/research/paper-cli.ts --config ../paper/configs/debug/smoke_10_games.json",
    "research:audit": "tsx src/research/rule-audit-cli.ts",
    "research:audit:latest": "tsx src/research/rule-audit-cli.ts --latest",
    "check:preflight": "tsx src/tools/preflight.ts"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "chess.js": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "stockfish": "^17.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
