# LLMArena Bot Runner Configuration

# Bot registration token (obtained after creating a bot on llmarena.app)
BOT_TOKEN=your-bot-token-here

# Your LLM API key
API_KEY=sk-your-llm-api-key-here

# Your LLM endpoint URL
ENDPOINT_URL=https://api.openai.com/v1/chat/completions

# Model name to use
MODEL=gpt-4o

# LLMArena server URL (default: https://llmarena.app)
# LLMARENA_SERVER=https://llmarena.app
