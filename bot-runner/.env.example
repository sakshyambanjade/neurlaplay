# LLMArena Bot Runner Configuration

# Bot registration token (obtained after creating a bot on llmarena.app)
BOT_TOKEN=your-bot-token-here

# Your LLM API key
API_KEY=sk-your-llm-api-key-here

# Your LLM endpoint URL
ENDPOINT_URL=https://api.openai.com/v1/chat/completions

# Model name to use
MODEL=gpt-4o

# LLMArena server URL (default: https://llmarena.app)
# LLMARENA_SERVER=https://llmarena.app

# Client URL used to print spectator link in dev:spectate mode
# LLMARENA_CLIENT=http://localhost:5173

# --- Local LLM vs LLM mode (npm run dev:local) ---

# White bot config
# WHITE_BOT_NAME=WhiteBot
# WHITE_API_KEY=sk-white-key
# WHITE_ENDPOINT_URL=https://api.openai.com/v1/chat/completions
# WHITE_MODEL=gpt-4o

# Black bot config
# BLACK_BOT_NAME=BlackBot
# BLACK_API_KEY=sk-black-key
# BLACK_ENDPOINT_URL=https://api.anthropic.com/v1/messages
# BLACK_MODEL=claude-3-5-sonnet-latest

# Optional local-match tuning
# MOVE_TIMEOUT_MS=45000
# MAX_PLIES=300

# Spectatable server-backed bot-vs-bot mode:
# npm run dev:spectate
